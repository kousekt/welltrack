generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  timezone     String   @default("UTC")
  createdAt    DateTime @default(now()) @map("created_at")

  symptoms       Symptom[]
  symptomLogs    SymptomLog[]
  moodLogs       MoodLog[]
  medications    Medication[]
  medicationLogs MedicationLog[]
  habits         Habit[]
  habitLogs      HabitLog[]

  @@map("users")
}

model Symptom {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  name       String
  category   String
  isActive   Boolean  @default(true) @map("is_active")

  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  symptomLogs SymptomLog[]

  @@map("symptoms")
}

model SymptomLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  symptomId  String   @map("symptom_id")
  severity   Int
  notes      String?
  loggedAt   DateTime @map("logged_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  symptom Symptom @relation(fields: [symptomId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
  @@map("symptom_logs")
}

model MoodLog {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  moodScore    Int      @map("mood_score")
  energyLevel  Int?     @map("energy_level")
  stressLevel  Int?     @map("stress_level")
  notes        String?
  loggedAt     DateTime @map("logged_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
  @@map("mood_logs")
}

model Medication {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  dosage    String?
  frequency String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  medicationLogs MedicationLog[]

  @@map("medications")
}

model MedicationLog {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  medicationId String    @map("medication_id")
  taken        Boolean
  takenAt      DateTime? @map("taken_at")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  medication Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("medication_logs")
}

model Habit {
  id           String   @id @default(uuid())
  userId       String?  @map("user_id")
  name         String
  trackingType String   @map("tracking_type")
  unit         String?
  isActive     Boolean  @default(true) @map("is_active")

  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  habitLogs HabitLog[]

  @@map("habits")
}

model HabitLog {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  habitId       String   @map("habit_id")
  valueBoolean  Boolean? @map("value_boolean")
  valueNumeric  Float?   @map("value_numeric")
  valueDuration Int?     @map("value_duration")
  notes         String?
  loggedAt      DateTime @map("logged_at")
  createdAt     DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
  @@map("habit_logs")
}
